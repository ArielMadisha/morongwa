# Morongwa - Errand Runner Marketplace
# Production Environment Configuration
# IMPORTANT: Update all sensitive values before deploying to production

PORT=5000
NODE_ENV=production

# ============================================
# MongoDB Atlas (Production Cluster)
# ============================================
# Replace with your production MongoDB Atlas URI
# Create a dedicated production cluster and user for security
MONGO_URI=

# ============================================
# JWT Authentication
# ============================================
# Generate a strong, random secret key for production
# Use: openssl rand -base64 32
JWT_SECRET="generate-a-strong-random-secret-key-for-production"

# ============================================
# Frontend & Backend URLs
# ============================================
FRONTEND_URL=https://www.morongwa.com
BACKEND_URL=https://api.morongwa.com

# ============================================
# SMTP Email Configuration (Gmail, SendGrid, etc.)
# ============================================
# For production, use a dedicated email service
# Gmail: Enable 2FA and generate App Password
# SendGrid: Use API key
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-production-email@gmail.com
SMTP_PASS=your-app-specific-password

# Mailer selection: set to `ethereal` in development to use Nodemailer's test account
# For production, leave empty or use a real SMTP provider and set SMTP_* variables
MAILER=

# Alternative: SendGrid
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=sg.your-sendgrid-api-key

# ============================================
# PayGate - South African Payment Gateway
# ============================================
# Get these from your PayGate merchant account
# https://www.paygate.co.za
PAYGATE_ID=your-production-paygate-id
PAYGATE_SECRET=your-production-paygate-secret
PAYGATE_URL=https://secure.paygate.co.za/payweb3/process.trans
# Flat ZAR fee added to every PayGate card transaction (default 5). Set to 0 to disable.
PAYGATE_FLAT_FEE_ZAR=5

# ============================================
# Logging
# ============================================
LOG_LEVEL=warn

# ============================================
# Admin Configuration (used by seed-admin script)
# ============================================
# Set these when running npm run seed-admin; never commit real values
ADMIN_EMAIL=admin@morongwa.com
ADMIN_PASSWORD=
ADMIN_NAME=Admin

# ============================================
# CORS & Security
# ============================================
# Allowed origins for CORS (comma-separated)
ALLOWED_ORIGINS=https://www.morongwa.com,https://morongwa.com

# ============================================
# Twilio (OTP, wallet SMS, money requests)
# ============================================
# Same config for: registration OTP, QR payment verification, money request notifications
# From https://console.twilio.com - Account SID and Auth Token
# SMS: Buy a number at Phone Numbers → Manage → Buy a number
# WhatsApp: Use sandbox for testing, or approved WhatsApp Business number for production
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_SMS_FROM=+1234567890
TWILIO_WHATSAPP_FROM=+1234567890

# Studio: WhatsApp chatbot flow (FW…). Set this so pushTwilioFlowV2.mjs updates the SAME flow your sender uses instead of creating a new orphan flow.
# TWILIO_STUDIO_FLOW_SID=

# Signed WhatsApp deep links (GET /api/wa/g/:token → 302 to wa.me). Stops tampering with ?text= payloads.
# If unset, JWT_SECRET is used when it is at least 16 characters. Prefer a dedicated secret in production.
# WA_LINK_SIGNING_SECRET=
# Public base for links in bot messages (default: {BACKEND_URL}/api/wa). Use a short branded domain if you add a reverse proxy.
# WA_LINK_PUBLIC_BASE=https://api.qwertymates.com/api/wa
# Comma-separated extra hostnames allowed in signed "share" links (default: FRONTEND_URL host + qwertymates.com).
# WA_PUBLIC_SHARE_HOSTS=www.example.com,example.com

# Optional: Strong secret for OTP hashing (default used if not set)
# OTP_SECRET=generate-a-strong-random-secret

# Optional: Block additional premium prefixes (comma-separated, digits only)
# Built-in: SA 087/089, US 900, UK 0870/0871/09xx. Add more as needed.
# OTP_BLOCK_PREFIXES=2787,2789,1900

# ============================================
# Rate Limiting
# ============================================
# Requests per 15 minutes per IP
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ============================================
# Session & Cookie Security
# ============================================
SESSION_SECRET=generate-a-strong-random-session-secret
SECURE_COOKIES=true
SAME_SITE_COOKIES=strict

# ============================================
# AWS S3 (Optional - for file uploads)
# ============================================
# AWS_ACCESS_KEY_ID=your-aws-access-key
# AWS_SECRET_ACCESS_KEY=your-aws-secret-key
# AWS_S3_BUCKET=morongwa-production-bucket
# AWS_S3_REGION=eu-west-1

# ============================================
# Sentry (Error Tracking - Optional)
# ============================================
# SENTRY_DSN=https://your-sentry-key@sentry.io/project-id

# ============================================
# Database Backups (Optional)
# ============================================
# BACKUP_SCHEDULE=daily
# BACKUP_RETENTION_DAYS=30

# ============================================
# Content Moderation (Sightengine - Optional)
# ============================================
# Block nudity and explicit content; report blocked uploads to admin.
# Get free API keys at https://sightengine.com
# When not set, all uploads pass (no moderation).
# SIGHTENGINE_API_USER=your-api-user
# SIGHTENGINE_API_SECRET=your-api-secret

# ============================================
# Feature Flags (Optional)
# ============================================
# FEATURE_PAYMENT_ENABLED=true
# FEATURE_NOTIFICATIONS_ENABLED=true
# FEATURE_CHAT_ENABLED=true

# ============================================
# WebRTC TURN (Recommended secure setup)
# ============================================
# Comma-separated TURN URIs for clients.
TURN_URLS=turn:your-turn-host:3478?transport=udp,turns:your-turn-host:5349?transport=tcp
# Shared secret for coturn REST auth (use-auth-secret=1, static-auth-secret=<same value>).
# This allows backend to mint short-lived TURN credentials per user.
TURN_SHARED_SECRET=replace-with-strong-random-secret
# Optional TTL for temporary TURN credentials (seconds).
TURN_TTL_SECONDS=3600
# Enforce temporary-only TURN credentials (disable static fallback).
TURN_ENFORCE_EPHEMERAL=1
# Legacy fallback (only used when TURN_SHARED_SECRET is missing; avoid in production).
# TURN_USERNAME=
# TURN_PASSWORD=
