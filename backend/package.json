{
  "name": "morongwa-backend",
  "version": "1.0.0",
  "description": "Errand-runner marketplace platform (Airbnb for errands)",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only server.ts",
    "dev:restart": "node scripts/start-dev.js",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:functional": "node scripts/smoke.mjs",
    "test:smoke:deploy": "node scripts/smoke-deploy.mjs",
    "lint": "eslint src --ext .ts",
    "create-admin": "ts-node-dev scripts/createAdmin.ts",
    "seed-admin": "ts-node-dev scripts/seedAdmin.ts",
    "seed-superadmin": "ts-node-dev scripts/seedSuperAdmin.ts",
    "migrate:product-supplier-source": "ts-node-dev scripts/migrateProductSupplierSource.ts",
    "seed:courier-rules": "ts-node-dev scripts/seedCourierRules.ts",
    "seed:external-suppliers": "ts-node-dev scripts/seedExternalSuppliers.ts",
    "sync:cj-stock": "ts-node-dev scripts/syncCjStock.ts",
    "deploy:frontend-remote": "node scripts/publishFrontendRemote.mjs",
    "deploy:frontend-remote:rebuild": "node scripts/publishFrontendRemote.mjs --rebuild",
    "deploy:twilio-flow": "node scripts/pushTwilioFlowV2.mjs",
    "deploy:production": "node scripts/deployProduction.mjs",
    "deploy:policy-remote": "node scripts/pushBackendPolicyRemote.mjs",
    "deploy:backend-remote": "node scripts/pushBackendFullRemote.mjs",
    "sync:prod-paygate-env": "node scripts/syncProdPayGateEnvRemote.mjs",
    "setup:realtime-remote": "node scripts/setupRealtimeInfraRemote.mjs",
    "setup:realtime-remote:dry": "node scripts/setupRealtimeInfraRemote.mjs --dry-run",
    "activate:legacy-users": "npx ts-node scripts/activateLegacyImportedUsers.ts",
    "activate:legacy-users:inactive": "npx ts-node scripts/activateLegacyImportedUsers.ts --inactive-only"
  },
  "keywords": [
    "marketplace",
    "errands",
    "gig-economy"
  ],
  "author": "Morongwa",
  "license": "MIT",
  "dependencies": {
    "@vitalets/google-translate-api": "^9.2.1",
    "axios": "^1.6.2",
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-mongo-sanitize": "^2.2.0",
    "express-rate-limit": "^7.1.5",
    "form-data": "^4.0.5",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "json2csv": "^6.0.0-alpha.2",
    "jsonwebtoken": "^9.0.2",
    "libphonenumber-js": "^1.12.41",
    "mongoose": "^8.21.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.13.0",
    "socket.io": "^4.6.0",
    "twilio": "^5.12.2",
    "winston": "^3.11.0",
    "xss-clean": "^0.1.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.3",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.10.0",
    "@types/nodemailer": "^6.4.14",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "eslint": "^8.54.0",
    "jest": "^29.7.0",
    "ssh2": "^1.17.0",
    "ts-jest": "^29.1.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.2"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "overrides": {
    "minimatch": "^9.0.9"
  }
}
