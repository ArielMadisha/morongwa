{
  "name": "morongwa-mobile",
  "version": "0.1.0",
  "private": true,
  "main": "expo/AppEntry",
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "smoke:checklist": "node ./scripts/smoke-checklist.mjs",
    "eas:whoami": "npx eas whoami",
    "eas:login": "npx eas login",
    "build:android:preview": "npx eas build --platform android --profile preview --non-interactive",
    "build:android:production": "npx eas build --platform android --profile production --non-interactive",
    "build:ios:preview": "npx eas build --platform ios --profile preview --non-interactive",
    "build:ios:preview:interactive": "npx eas build --platform ios --profile preview",
    "build:ios:simulator": "npx eas build --platform ios --profile preview-simulator --non-interactive",
    "build:ios:production": "npx eas build --platform ios --profile production --non-interactive",
    "submit:android:production": "npx eas submit --platform android --profile production --non-interactive",
    "submit:ios:production": "npx eas submit --platform ios --profile production --non-interactive"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "axios": "^1.13.2",
    "expo": "~54.0.0",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-constants": "~18.0.13",
    "expo-document-picker": "~14.0.8",
    "expo-haptics": "~15.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-status-bar": "~3.0.9",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-qrcode-svg": "^6.3.21",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "^0.21.0",
    "react-native-webrtc": "^124.0.7",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "~19.1.10",
    "typescript": "~5.9.2"
  },
  "expo": {
    "doctor": {
      "reactNativeDirectoryCheck": {
        "exclude": [
          "react-native-webrtc"
        ]
      }
    }
  }
}
