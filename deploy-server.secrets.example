# Copy to deploy-server.secrets in the project root (gitignored).
# NEVER put a real password in this .example file (it may be committed).
# NEVER commit deploy-server.secrets.
#
#   copy deploy-server.secrets.example deploy-server.secrets
#
# In deploy-server.secrets only, set (password immediately after =):
#   DEPLOY_SSH_PASSWORD=YourRealPassword
#
# Or one-time in PowerShell:
#   $env:DEPLOY_SSH_PASSWORD='YourReal'; npm run deploy:frontend-remote:rebuild

# Realtime infra (TURN + livestream) for mobile
# Use your public host/IP if no DNS yet (e.g. 165.227.237.142)
TURN_REALM=qwertymates.com
TURN_USERNAME=morongwa_turn_user
TURN_PASSWORD=replace-with-long-random-secret

# Livestream playback host/path (nginx serves /hls from this path)
PUBLIC_APP_DOMAIN=qwertymates.com
LIVESTREAM_HLS_DOMAIN=qwertymates.com
LIVESTREAM_TLS_DOMAIN=qwertymates.com
LIVESTREAM_HLS_PATH=/var/www/morongwa-hls
LIVESTREAM_HLS_PORT=8081
